# =========================
# Server-side (chatbot)
# =========================
# REQUIRED. Used by /api/chat.ts on Vercel. Keep this OUT of any VITE_ var —
# anything prefixed with VITE_ gets bundled into the client and exposed to the public.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =========================
# Client-side (EmailJS — used by both the contact form and the chatbot lead notifier)
# =========================
VITE_EMAILJS_SERVICE_ID=service_xxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxx

# Where chatbot lead notifications + contact form messages are delivered.
VITE_EMAILJS_RECIPIENT_EMAIL=contact@apexifylabs.com
VITE_CONTACT_EMAIL=contact@apexifylabs.com

# Social links (optional)
VITE_LINKEDIN_URL=https://www.linkedin.com/company/apexifylabs
VITE_TWITTER_URL=https://twitter.com/apexifylabs
